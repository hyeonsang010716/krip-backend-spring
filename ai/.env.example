# Krip AI 서버 환경변수 — 핵심 AI 추론 전용. DB/Redis/Storage 설정 없음.

# 서버
ENVIRONMENT=DEV
HOST=0.0.0.0
PORT=8000

# 로깅
LOG_LEVEL=INFO
LOG_FORMAT=console
# 컨테이너에서 콘솔만 쓰려면 빈 값으로 두세요.
LOG_FILE_PATH=

# 인증 — Spring(게이트웨이)의 ACCESS_TOKEN 과 반드시 동일해야 함.
ACCESS_TOKEN=change-me-access-token

# LLM (Gemini)
GOOGLE_GEMINI_API_KEY=

# Papago (Naver Developers)
PAPAGO_CLIENT_ID=
PAPAGO_CLIENT_SECRET=
