# ──────────────────── 서버 ────────────────────
PORT=8000
ENVIRONMENT=DEV

# ──────────────────── CORS ────────────────────
FRONTEND_URL=https://krip.site
LOCAL_FRONTEND_URL=https://localhost:3000

# ──────────────────── PostgreSQL ────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_NAME=

# ──────────────────── MongoDB ────────────────────
MONGODB_HOST=mongodb
MONGODB_PORT=27017
MONGODB_USER=
MONGODB_PASSWORD=
MONGODB_NAME=

# ──────────────────── Redis ────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# ──────────────────── 인증 ────────────────────
# 서비스 간 글로벌 Bearer 토큰
ACCESS_TOKEN=change-me-access-token
# 유저 로그인 JWT (HS256).
USER_LOGIN_JWT_SECRET_KEY=change-me-please-use-a-long-random-secret
USER_LOGIN_JWT_EXPIRATION_DAYS=1
USER_LOGIN_COOKIE_NAME=utk
# 공유 링크 JWT (HS256). 운영에선 반드시 별도 시크릿으로 교체.
SHARE_JWT_SECRET_KEY=change-me-please-use-a-long-random-secret
SHARE_JWT_EXPIRATION_DAYS=30

# ──────────────────── Google OAuth ────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
OAUTH_REDIRECT_BASE_URL=http://localhost:8000

# ──────────────────── Object Storage (NaverCloud S3 호환) ────────────────────
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=kr-standard
S3_BUCKET_NAME=
S3_ENDPOINT_URL=https://kr.object.ncloudstorage.com

# ──────────────────── 채팅 (fan-out) ────────────────────
# in_process(단일 노드) | node_channel(다중 노드 Redis Pub/Sub)
FANOUT_MODE=in_process
# 다중 노드 식별자. 미설정 시 호스트명 → node-local 폴백.
NODE_ID=node-local
CHAT_DEDUPE_REDIS_DB=1

# ──────────────────── FCM (푸시 알림) ────────────────────
# false 또는 키 경로 미설정 시 푸시 발송만 비활성(토큰/뮤트/인박스는 정상).
# 서비스 계정 JSON 을 secrets/ 에 두면 docker-compose 가 /backend/secrets 로 마운트(ro).
FCM_ENABLED=true
FCM_CREDENTIALS_PATH=/backend/secrets/fcm-service-account.json

# ──────────────────── DB 스키마 ────────────────────
# 스키마 변경은 Flyway, 검증만 Hibernate(validate).
FLYWAY_ENABLED=true
JPA_DDL_AUTO=validate

# ──────────────────── 기타 ────────────────────
LOG_LEVEL=INFO
# 탈퇴 계정 정리 cron (기본 매일 KST 04:00).
WITHDRAW_PURGE_CRON=0 0 4 * * *
# @Scheduled 스레드 풀 크기 (잡당 1스레드, reconcile/heartbeat 분리).
SCHEDULING_POOL_SIZE=4
