# ──────────────────── 서버 ────────────────────
PORT=8000
ENVIRONMENT=DEV

# ──────────────────── AI 서비스 (FastAPI) ────────────────────
# 핵심 AI 로직 전담 FastAPI. DB/인증/영속화는 Spring, AI 추론만 여기로 위임.
# docker-compose 내부망에선 http://krip-ai:8000, 로컬 단독 실행 시 http://localhost:8001.
AI_ENABLED=true
AI_SERVICE_URL=http://krip-ai:8000
AI_CONNECT_TIMEOUT_MS=3000
# read 타임아웃 — tour 는 일자별 LLM 순차 호출이라 travel_days=3 worst-case 까지 여유 있게(180s).
AI_READ_TIMEOUT_MS=180000
AI_CIRCUIT_FAILURE_THRESHOLD=5
AI_CIRCUIT_OPEN_MS=30000
# 서비스 간 인증은 기존 ACCESS_TOKEN 재사용 — FastAPI .env 의 ACCESS_TOKEN 과 반드시 동일해야 함.

# ──────────────────── CORS ────────────────────
FRONTEND_URL=https://krip.site
LOCAL_FRONTEND_URL=https://localhost:3000

# ──────────────────── PostgreSQL ────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_NAME=

# ──────────────────── MongoDB ────────────────────
MONGODB_HOST=mongodb
MONGODB_PORT=27017
MONGODB_USER=
MONGODB_PASSWORD=
MONGODB_NAME=

# ──────────────────── Redis ────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# ──────────────────── 인증 ────────────────────
# 서비스 간 글로벌 Bearer 토큰
ACCESS_TOKEN=change-me-access-token
# 유저 로그인 JWT (HS256).
USER_LOGIN_JWT_SECRET_KEY=change-me-please-use-a-long-random-secret
USER_LOGIN_JWT_EXPIRATION_DAYS=1
USER_LOGIN_COOKIE_NAME=utk
# 공유 링크 JWT (HS256). 운영에선 반드시 별도 시크릿으로 교체.
SHARE_JWT_SECRET_KEY=change-me-please-use-a-long-random-secret
SHARE_JWT_EXPIRATION_DAYS=30

# ──────────────────── Google OAuth ────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
OAUTH_REDIRECT_BASE_URL=http://localhost:8000

# ──────────────────── Object Storage (NaverCloud S3 호환) ────────────────────
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=kr-standard
S3_BUCKET_NAME=
S3_ENDPOINT_URL=https://kr.object.ncloudstorage.com

# ──────────────────── 채팅 (fan-out) ────────────────────
# in_process(단일 노드) | redis_stream(다중 노드 Redis Stream)
FANOUT_MODE=in_process
# 다중 노드 식별자. 재시작에도 안정적이어야 함(consumer group 커서 이어받기). 미설정 시 호스트명 → node-local 폴백.
NODE_ID=node-local
CHAT_DEDUPE_REDIS_DB=1

# ──────────────────── FCM (푸시 알림) ────────────────────
# false 또는 키 경로 미설정 시 푸시 발송만 비활성(토큰/뮤트/인박스는 정상).
# 서비스 계정 JSON 을 secrets/ 에 두면 docker-compose 가 /backend/secrets 로 마운트(ro).
FCM_ENABLED=true
FCM_CREDENTIALS_PATH=/backend/secrets/fcm-service-account.json
# FCM HTTP 타임아웃(ms).
FCM_CONNECT_TIMEOUT_MS=3000
FCM_READ_TIMEOUT_MS=5000
# FCM 서킷 브레이커: 연속 실패 임계치 + open 유지 시간(ms).
FCM_CIRCUIT_FAILURE_THRESHOLD=5
FCM_CIRCUIT_OPEN_MS=30000

# ──────────────────── DB 스키마 ────────────────────
# 스키마 변경은 Flyway, 검증만 Hibernate(validate).
FLYWAY_ENABLED=true
JPA_DDL_AUTO=validate

# ──────────────────── 기타 ────────────────────
LOG_LEVEL=INFO
# 탈퇴 계정 정리 cron (기본 매일 KST 04:00).
WITHDRAW_PURGE_CRON=0 0 4 * * *
# 전역 @Scheduled 스레드 풀 크기 (reconcile/heartbeat/purge).
SCHEDULING_POOL_SIZE=4
# 채팅 WS 세션 하트비트/복구 전용 스레드 풀 크기.
CHAT_WS_POOL_SIZE=4
# 채팅 FCM 푸시(블로킹 I/O) 전용 풀 크기 + 큐 상한.
PUSH_EXECUTOR_POOL_SIZE=4
PUSH_EXECUTOR_QUEUE_CAPACITY=500
# 접속 시 unread 백그라운드 복구(블로킹 Mongo) 전용 풀 크기 + 큐 상한.
RECOVER_EXECUTOR_POOL_SIZE=4
RECOVER_EXECUTOR_QUEUE_CAPACITY=500
# 이미지 처리(decode/resize) 동시 한도 + 유계 큐. 포화 시 429.
IMAGE_PROCESS_POOL_SIZE=4
IMAGE_PROCESS_QUEUE_CAPACITY=16
# variant(original/small/medium) S3 병렬 업로드 풀 크기 + 큐 상한.
IMAGE_UPLOAD_POOL_SIZE=12
IMAGE_UPLOAD_QUEUE_CAPACITY=24
# 채팅 WS op(send/read): 컨테이너 I/O 스레드와 격리. 세션 단위 직렬, 포화 시 server_busy 백프레셔.
CHAT_OP_POOL_SIZE=16
CHAT_OP_QUEUE_CAPACITY=1000
# 세션당 대기 한도(초과 시 server_busy).
CHAT_OP_SESSION_MAX_QUEUED=64
